{
  "info": {
    "name": "AssurMoi - Dernières Routes",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "DELETE /dossiers/:id",
      "request": {
        "method": "DELETE",
        "url": { "raw": "{{baseUrl}}/dossiers/1", "host": ["{{baseUrl}}"], "path": ["dossiers", "1"] }
      }
    },
    {
      "name": "PUT /documents/:id",
      "request": {
        "method": "PUT",
        "header": [
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"est_valide\": true,\n  \"chemin_fichier\": \"/nouveau/chemin/fichier.pdf\"\n}"
        },
        "url": { "raw": "{{baseUrl}}/documents/1", "host": ["{{baseUrl}}"], "path": ["documents", "1"] }
      }
    },
    {
      "name": "DELETE /documents/:id",
      "request": {
        "method": "DELETE",
        "url": { "raw": "{{baseUrl}}/documents/1", "host": ["{{baseUrl}}"], "path": ["documents", "1"] }
      }
    },
    {
      "name": "PUT /action-logs/:id",
      "request": {
        "method": "PUT",
        "header": [
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"details\": \"Correction de la description de l'action log\"\n}"
        },
        "url": { "raw": "{{baseUrl}}/action-logs/1", "host": ["{{baseUrl}}"], "path": ["action-logs", "1"] }
      }
    },
    {
      "name": "DELETE /action-logs/:id",
      "request": {
        "method": "DELETE",
        "url": { "raw": "{{baseUrl}}/action-logs/1", "host": ["{{baseUrl}}"], "path": ["action-logs", "1"] }
      }
    }
  ],
  "auth": {
    "type": "bearer",
    "bearer": [
      {
        "key": "token",
        "value": "{{jwt_token}}",
        "type": "string"
      }
    ]
  }
}