  "item": [
    {
      "name": "1. Roles",
      "item": [
        {
          "name": "Get all Roles",
          "request": { "method": "GET", "url": { "raw": "{{baseUrl}}/roles", "host": ["{{baseUrl}}"], "path": ["roles"] } }
        },
        {
          "name": "Create Role",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"label\": \"Gestionnaire\"\n}" },
            "url": { "raw": "{{baseUrl}}/roles", "host": ["{{baseUrl}}"], "path": ["roles"] }
          }
        }
      ]
    },
    {
