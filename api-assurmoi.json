            "url": { "raw": "{{baseUrl}}/sinistres", "host": ["{{baseUrl}}"], "path": ["sinistres"] }
          }
        },
        {
          "name": "Update Sinistre",
          "request": {
            "method": "PUT",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"statut\": \"En attente de validation\"\n}" },
            "url": { "raw": "{{baseUrl}}/sinistres/1", "host": ["{{baseUrl}}"], "path": ["sinistres", "1"] }
          }
        }
      ]
    },
